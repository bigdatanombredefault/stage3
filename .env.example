# ─────────────────────────────────────────────────────────────────────────────
# Stage 3 Cluster — Environment Variables
#
# Copy this file to .env and fill in the values for EACH machine.
# Variables marked SHARED are the same on every PC.
# Variables marked PER-MACHINE must be different on every PC.
# ─────────────────────────────────────────────────────────────────────────────

# ── SHARED (same value on every machine) ─────────────────────────────────────

# LAN IP of the PC running ActiveMQ and Nginx (the "master" node).
MASTER_NODE_IP=192.168.1.10

# Comma-separated list of ALL cluster node LAN IPs (no spaces).
CLUSTER_NODES_LIST=192.168.1.10,192.168.1.11,192.168.1.12

# ── PER-MACHINE (set to THIS machine's LAN IP) ────────────────────────────────

# The LAN IP of the machine where you are running `docker compose up`.
# Run `hostname -I | awk '{print $1}'` to find it.
CURRENT_NODE_IP=192.168.1.10

# ── NGINX UPSTREAM IPs (only needed on the master node) ──────────────────────
# Set PC1_IP .. PC3_IP to your actual cluster node IPs.
# For a 3-node cluster, duplicate: PC4_IP=PC1_IP, PC5_IP=PC2_IP, PC6_IP=PC3_IP.
# For a 6-node cluster, set each to a distinct IP.
PC1_IP=192.168.1.10
PC2_IP=192.168.1.11
PC3_IP=192.168.1.12
PC4_IP=192.168.1.10
PC5_IP=192.168.1.11
PC6_IP=192.168.1.12

# ── OPTIONAL TUNING ───────────────────────────────────────────────────────────

# Absolute path on the HOST machine where book files are stored.
# Default: ./datalake (relative to docker-compose.yml)
# HOST_DATA_VOLUME_PATH=/data/datalake

# Enable async ingestion (returns 202 immediately, downloads in background).
# Default: true
# INGESTION_ASYNC_ENABLED=true
# INGESTION_ASYNC_WORKERS=4

# Enable datalake replication (each book copied to one other node).
# Default: true
# DATALAKE_REPLICATION_ENABLED=true

# Number of concurrent ActiveMQ consumer threads per indexer node.
# Default: 2
# INDEXER_CONSUMERS=2

# Maximum redelivery attempts for a failed indexing message.
# Default: 5
# INDEXER_MAX_DELIVERIES=5
