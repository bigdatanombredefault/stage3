# ─────────────────────────────────────────────────────────────────────────────
# cluster-shared.env — COMMIT THIS FILE AND PUSH TO GITHUB.
#
# This file holds the IPs that are the same on every machine.
# Workflow:
#   1. The group leader fills in the real lab IPs below and pushes to GitHub.
#   2. Every PC runs:  git pull  (to get this updated file)
#   3. Every PC runs the setup command from CLUSTER_DEPLOYMENT.md §Step 3
#      to generate its local .env from this file + its own CURRENT_NODE_IP.
#
# DO NOT put CURRENT_NODE_IP here — that is different on each PC.
# ─────────────────────────────────────────────────────────────────────────────

# IP of the PC running ActiveMQ + Nginx (usually PC1 / the "master").
MASTER_NODE_IP=192.168.1.10

# All cluster node LAN IPs, comma-separated (no spaces).
CLUSTER_NODES_LIST=192.168.1.10,192.168.1.11,192.168.1.12

# ── Nginx upstream IPs ───────────────────────────────────────────────────────
# For a 3-node cluster: PC4=PC1, PC5=PC2, PC6=PC3 (nginx deduplicates them).
# For a 6-node cluster: set each to a distinct IP.
PC1_IP=192.168.1.10
PC2_IP=192.168.1.11
PC3_IP=192.168.1.12
PC4_IP=192.168.1.10
PC5_IP=192.168.1.11
PC6_IP=192.168.1.12
